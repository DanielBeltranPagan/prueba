import SwiftUI
import WebKit

// MARK: - Main View
struct ContentView: View {
    @AppStorage("last_url_saved") private var urlText: String = ""
    @State private var selectedResolution = "1080p"
    @State private var showWebView = false

    let resolutions = ["720p", "1080p", "2K", "4K"]

    var body: some View {
        NavigationStack {
            VStack(spacing: 25) {
                Text("WebView Resolution Pro")
                    .font(.system(size: 24, weight: .bold))
                    .padding(.top, 40)

                VStack(alignment: .leading, spacing: 8) {
                    Text("URL de destino").font(.caption).foregroundColor(.gray)
                    TextField("Introduce la URL (ej: orbys.eu)", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .textInputAutocapitalization(.never)
                        .keyboardType(.URL)
                }
                .padding(.horizontal)

                VStack(alignment: .leading, spacing: 10) {
                    Text("Resolución Objetivo:").font(.subheadline).bold()
                    Picker("Resolución", selection: $selectedResolution) {
                        ForEach(resolutions, id: \.self) { Text($0).tag($0) }
                    }
                    .pickerStyle(.segmented)
                }
                .padding(.horizontal)

                Spacer()

                Button(action: { showWebView = true }) {
                    Text("LANZAR EN \(selectedResolution)")
                        .font(.headline).frame(maxWidth: .infinity).padding()
                        .background(urlText.isEmpty ? Color.gray.opacity(0.3) : Color.blue)
                        .foregroundColor(.white).cornerRadius(12)
                }
                .disabled(urlText.isEmpty)
                .padding(.horizontal).padding(.bottom, 30)
            }
            .navigationDestination(isPresented: $showWebView) {
                WebViewManagerView(urlString: urlText, resolution: selectedResolution)
            }
        }
    }
}

// MARK: - Manager View
struct WebViewManagerView: View {
    let urlString: String
    let resolution: String
    @State private var webSize: (w: Int, h: Int) = (0, 0)
    @State private var isReady: Bool = false 
    @State private var errorMessage: String? = nil

    var body: some View {
        ZStack {
            WebViewContainer(urlString: urlString, resolution: resolution, webSize: $webSize, isReady: $isReady, errorMessage: $errorMessage)
                .ignoresSafeArea(.container, edges: .bottom)
                .opacity(isReady ? 1 : 0)
                .animation(.easeInOut(duration: 0.5), value: isReady)

            if !isReady && errorMessage == nil {
                Color(UIColor.systemBackground).ignoresSafeArea()
                VStack(spacing: 20) {
                    ProgressView().scaleEffect(1.3)
                    Text("Sincronizando entorno y píxeles...").font(.footnote).foregroundColor(.gray)
                }
            }
        }
        .toolbar {
            ToolbarItem(placement: .principal) {
                Text(isReady ? "\(webSize.w) × \(webSize.h) px" : "Configurando...")
                    .font(.system(size: 14, weight: .bold, design: .monospaced)).foregroundColor(.blue)
            }
        }
    }
}

// MARK: - WebView Container
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    let resolution: String
    @Binding var webSize: (w: Int, h: Int)
    @Binding var isReady: Bool
    @Binding var errorMessage: String?

    func makeUIView(context: Context) -> WKWebView {
        let config = WKWebViewConfiguration()
        config.userContentController.add(context.coordinator, name: "resObserver")
        config.defaultWebpagePreferences.preferredContentMode = .desktop
        
        let webView = WKWebView(frame: .zero, configuration: config)
        webView.navigationDelegate = context.coordinator
        webView.customUserAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/118.0.0.0 Safari/537.36"
        
        context.coordinator.setupCookies(webView: webView)
        loadURL(webView)
        return webView
    }

    func loadURL(_ webView: WKWebView) {
        let trimmed = urlString.trimmingCharacters(in: .whitespaces)
        let formatted = trimmed.lowercased().hasPrefix("http") ? trimmed : "https://\(trimmed)"
        if let url = URL(string: formatted) {
            webView.load(URLRequest(url: url))
        }
    }

    func updateUIView(_ uiView: WKWebView, context: Context) {}
    func makeCoordinator() -> Coordinator { Coordinator(self) }

    class Coordinator: NSObject, WKNavigationDelegate, WKScriptMessageHandler {
        var parent: WebViewContainer
        weak var webView: WKWebView?

        init(_ parent: WebViewContainer) {
            self.parent = parent
            super.init()
            NotificationCenter.default.addObserver(self, selector: #selector(onRotation), name: UIDevice.orientationDidChangeNotification, object: nil)
        }

        @objc func onRotation() {
            guard let webView = webView else { return }
            parent.isReady = false
            // Pequeña pausa para que el frame de la webView se actualice antes de recalcular
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.3) {
                self.applyResolution(webView)
            }
        }

        func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
            self.webView = webView
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.6) {
                self.applyResolution(webView)
            }
        }

        func userContentController(_ userContentController: WKUserContentController, didReceive message: WKScriptMessage) {
            if let dict = message.body as? [String: Int] {
                parent.webSize = (dict["w"] ?? 0, dict["h"] ?? 0)
                DispatchQueue.main.asyncAfter(deadline: .now() + 0.4) {
                    withAnimation { self.parent.isReady = true }
                }
            }
        }

        func setupCookies(webView: WKWebView) {
            let trimmed = parent.urlString.trimmingCharacters(in: .whitespaces)
            let formatted = trimmed.lowercased().hasPrefix("http") ? trimmed : "https://\(trimmed)"
            
            guard let url = URL(string: formatted), 
                  let host = url.host, host.contains("orbys.eu") else { return }

            let cookieStore = webView.configuration.websiteDataStore.httpCookieStore
            let expiration = Date(timeIntervalSinceNow: 31_536_000)

            func createCookie(name: String, value: String) {
                let props: [HTTPCookiePropertyKey: Any] = [
                    .name: name,
                    .value: value,
                    .domain: ".orbys.eu",
                    .path: "/",
                    .expires: expiration
                ]
                if let cookie = HTTPCookie(properties: props) {
                    cookieStore.setCookie(cookie)
                }
            }
            
            createCookie(name: "orbys-consent-cookie", value: "true")
            createCookie(name: "preferencia-usuario", value: "valor-personalizado")
        }

        private func applyResolution(_ webView: WKWebView) {
            let resMap: [String: (CGFloat, CGFloat)] = [
                "720p": (1280, 720), "1080p": (1920, 1080), "2K": (2560, 1440), "4K": (3840, 2160)
            ]
            let spec = resMap[parent.resolution] ?? (1920, 1080)
            
            // Lógica de intercambio para Portrait
            let isLandscape = webView.bounds.width > webView.bounds.height
            let targetW = isLandscape ? spec.0 : spec.1
            let targetH = isLandscape ? spec.1 : spec.0
            
            // El factor de escala siempre se basa en el ancho físico actual
            let scale = webView.bounds.width / targetW

            let js = """
                var meta = document.querySelector('meta[name="viewport"]') || document.createElement('meta');
                meta.name = 'viewport';
                meta.content = 'width=\(Int(targetW)), initial-scale=\(scale), minimum-scale=\(scale), maximum-scale=\(scale), user-scalable=no';
                document.head.appendChild(meta);
                
                // Forzar el ancho del body para evitar layouts rotos en portrait
                document.body.style.width = '\(Int(targetW))px';
                
                setTimeout(function() {
                    window.webkit.messageHandlers.resObserver.postMessage({
                        w: \(Int(targetW)), 
                        h: \(Int(targetH))
                    });
                }, 300);
            """
            webView.evaluateJavaScript(js)
        }
    }
}
