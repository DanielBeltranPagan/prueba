import SwiftUI

@main
struct pruebaApp: App {
    var body: some Scene {
        WindowGroup {
            ContentView()
        }
    }
}

import SwiftUI

struct ContentView: View {
    @AppStorage("url_guardada") private var urlText: String = ""
    @State private var showWebView = false

    var body: some View {
        NavigationStack {
            VStack(spacing: 20) {
                Text("Configurador iOS")
                    .font(.title2).bold()

                TextField("Introduce una URL", text: $urlText)
                    .textFieldStyle(.roundedBorder)
                    .keyboardType(.URL)
                    .autocorrectionDisabled(true)
                    .textInputAutocapitalization(.never)
                    .padding(.horizontal)

                Button("ABRIR") {
                    showWebView = true
                }
                .disabled(urlText.isEmpty)
            }
            .padding(.top, 40)
            .navigationDestination(isPresented: $showWebView) {
                WebViewWrapper(urlString: urlText)
                    .ignoresSafeArea(edges: .bottom)
            }
        }
    }
}


import SwiftUI
import WebKit

struct WebViewWrapper: UIViewControllerRepresentable {
    let urlString: String

    func makeUIViewController(context: Context) -> WebViewController {
        let vc = WebViewController()
        vc.urlString = urlString
        return vc
    }

    func updateUIViewController(_ uiViewController: WebViewController, context: Context) {}
}

class WebViewController: UIViewController, WKNavigationDelegate {
    var urlString: String = ""
    private var webView: WKWebView!

    override func viewDidLoad() {
        super.viewDidLoad()

        webView = WKWebView(frame: view.bounds)
        webView.autoresizingMask = [.flexibleWidth, .flexibleHeight]
        webView.navigationDelegate = self
        webView.allowsBackForwardNavigationGestures = true
        view.addSubview(webView)

        var url = urlString.trimmingCharacters(in: .whitespaces)
        if !url.hasPrefix("http") { url = "https://\(url)" }
        if let finalURL = URL(string: url) {
            webView.load(URLRequest(url: finalURL))
        }
    }

    // Inyecta autocomplete cuando carga la página
    func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
        webView.evaluateJavaScript("""
            document.querySelectorAll('input[type="password"]')
                .forEach(f => f.setAttribute('autocomplete', 'current-password'));
            document.querySelectorAll('input[type="email"], input[type="text"]')
                .forEach(f => f.setAttribute('autocomplete', 'username'));
        """, completionHandler: nil)
    }
}
