import SwiftUI

@main
struct pruebaApp: App {
    var body: some Scene {
        WindowGroup {
            ContentView() // Aquí se inicia tu vista principal
        }
    }
}

import SwiftUI
import WebKit

// MARK: - VISTA PRINCIPAL (UI)
struct ContentView: View {
    // @AppStorage guarda el texto automáticamente en el dispositivo.
    @AppStorage("last_url_saved") private var urlText: String = ""
    @State private var selectedResolution = "720p"
    @State private var showWebView = false
    
    let resolutions = ["720p", "1080p", "2K", "4K"]
    
    var body: some View {
        NavigationStack {
            VStack(spacing: 25) {
                // Título superior
                Text("Configurador iOS")
                    .font(.system(size: 24, weight: .bold))
                    .padding(.top, 20)
                
                // Campo de texto para la URL
                VStack(alignment: .leading, spacing: 8) {
                    Text("URL de destino")
                        .font(.caption)
                        .foregroundColor(.gray)
                        .padding(.leading, 4)
                    
                    TextField("Introduce la URL (ej: github.io/...)", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .textContentType(.URL)
                        .keyboardType(.URL)
                        .autocorrectionDisabled(true)
                        .textInputAutocapitalization(.never)
                }
                .padding(.horizontal)
                
                // Selector de resolución
                VStack(alignment: .leading, spacing: 10) {
                    Text("Selección de Resolución:")
                        .font(.subheadline)
                        .bold()
                    
                    Picker("Resolución", selection: $selectedResolution) {
                        ForEach(resolutions, id: \.self) { res in
                            Text(res).tag(res)
                        }
                    }
                    .pickerStyle(.segmented)
                }
                .padding(.horizontal)
                
                Spacer()
                
                // Botón Principal
                Button(action: {
                    if !urlText.trimmingCharacters(in: .whitespaces).isEmpty {
                        showWebView = true
                    }
                }) {
                    Text("ABRIR WEBVIEW")
                        .font(.headline)
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(urlText.isEmpty ? Color.gray.opacity(0.3) : Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(12)
                }
                .disabled(urlText.isEmpty)
                .padding(.horizontal)
                .padding(.bottom, 30)
            }
            .background(Color(.systemBackground))
            // Navegación hacia la pantalla de la WebView
            .navigationDestination(isPresented: $showWebView) {
                WebViewContainer(urlString: urlText)
                    .navigationTitle(urlText)
                    .navigationBarTitleDisplayMode(.inline)
            }
        }
    }
}

// MARK: - MOTOR WEBVIEW (Optimizado)
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    
    // El ProcessPool ayuda a que las cookies y el autocompletado se mantengan consistentes
    static let sharedProcessPool = WKProcessPool()
    
    func makeUIView(context: Context) -> WKWebView {
        let configuration = WKWebViewConfiguration()
        configuration.processPool = Self.sharedProcessPool
        
        let webView = WKWebView(frame: .zero, configuration: configuration)
        webView.allowsBackForwardNavigationGestures = true
        
        return webView
    }
    
    func updateUIView(_ uiView: WKWebView, context: Context) {
        // Limpiamos la URL y aseguramos que tenga HTTPS
        var finalUrl = urlString.trimmingCharacters(in: .whitespaces)
        
        if !finalUrl.lowercased().hasPrefix("http") {
            finalUrl = "https://\(finalUrl)"
        }
        
        guard let url = URL(string: finalUrl) else { return }
        
        // Solo cargamos si la URL es diferente a la actual para evitar bucles
        if uiView.url?.absoluteString != url.absoluteString {
            let request = URLRequest(url: url)
            uiView.load(request)
        }
    }
}
