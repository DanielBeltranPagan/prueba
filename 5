import SwiftUI
import WebKit

// MARK: - Main View
struct ContentView: View {
    @AppStorage("last_url_saved") private var urlText: String = ""
    @State private var selectedResolution = "1080p"
    @State private var showWebView = false

    let resolutions = ["720p", "1080p", "2K", "4K"]

    var body: some View {
        NavigationStack {
            VStack(spacing: 25) {
                Text("WebView Resolution Pro")
                    .font(.system(size: 24, weight: .bold))
                    .padding(.top, 40)

                VStack(alignment: .leading, spacing: 8) {
                    Text("URL de destino")
                        .font(.caption).foregroundColor(.gray)
                    TextField("Introduce la URL (ej: youtube.com)", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .textContentType(.URL)
                        .keyboardType(.URL)
                        .autocorrectionDisabled(true)
                        .textInputAutocapitalization(.never)
                }
                .padding(.horizontal)

                VStack(alignment: .leading, spacing: 10) {
                    Text("Resolución Objetivo (Ancho):")
                        .font(.subheadline).bold()
                    Picker("Resolución", selection: $selectedResolution) {
                        ForEach(resolutions, id: \.self) { res in
                            Text(res).tag(res)
                        }
                    }
                    .pickerStyle(.segmented)
                }
                .padding(.horizontal)

                Spacer()

                Button(action: {
                    if !urlText.trimmingCharacters(in: .whitespaces).isEmpty {
                        showWebView = true
                    }
                }) {
                    Text("LANZAR EN \(selectedResolution)")
                        .font(.headline)
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(urlText.isEmpty ? Color.gray.opacity(0.3) : Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(12)
                }
                .disabled(urlText.isEmpty)
                .padding(.horizontal).padding(.bottom, 30)
            }
            .navigationDestination(isPresented: $showWebView) {
                WebViewManagerView(urlString: urlText, resolution: selectedResolution)
                    .id(urlText + selectedResolution)
            }
        }
    }
}

// MARK: - Manager View
struct WebViewManagerView: View {
    let urlString: String
    let resolution: String

    // w = ancho CSS que ve el sitio web (ej: 1280 para 720p)
    // h = altura visible en pantalla en px CSS (sin scroll)
    @State private var webWidth: Int = 0
    @State private var webHeight: Int = 0
    @State private var errorMessage: String? = nil

    var body: some View {
        Group {
            if let error = errorMessage {
                VStack(spacing: 16) {
                    Image(systemName: "wifi.slash")
                        .font(.system(size: 48))
                        .foregroundColor(.gray)
                    Text("Error de navegación")
                        .font(.headline)
                    Text(error)
                        .font(.caption)
                        .foregroundColor(.secondary)
                        .multilineTextAlignment(.center)
                        .padding(.horizontal)
                }
            } else {
                WebViewContainer(
                    urlString: urlString,
                    resolution: resolution,
                    webWidth: $webWidth,
                    webHeight: $webHeight,
                    errorMessage: $errorMessage
                )
                .ignoresSafeArea(.container, edges: .bottom)
            }
        }
        .toolbar {
            ToolbarItem(placement: .principal) {
                HStack(spacing: 6) {
                    Image(systemName: errorMessage != nil ? "exclamationmark.triangle" : "viewfinder")
                    if errorMessage != nil {
                        Text("Error")
                            .font(.system(size: 14, weight: .bold))
                    } else if webWidth > 0 {
                        // Ancho × alto visible del viewport configurado
                        Text("\(webWidth) × \(webHeight) px")
                            .font(.system(size: 14, weight: .bold, design: .monospaced))
                    } else {
                        Text("Cargando…")
                            .font(.system(size: 14, weight: .bold, design: .monospaced))
                    }
                }
                .foregroundColor(errorMessage != nil ? .orange : .blue)
            }
        }
        .navigationBarTitleDisplayMode(.inline)
    }
}

// MARK: - WebView Container
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    let resolution: String
    @Binding var webWidth: Int
    @Binding var webHeight: Int
    @Binding var errorMessage: String?

    /// Ancho lógico CSS que queremos forzar en el sitio web
    var targetWidth: CGFloat {
        switch resolution {
        case "720p":  return 1280
        case "1080p": return 1920
        case "2K":    return 2560
        case "4K":    return 3840
        default:      return 1920
        }
    }

    func makeUIView(context: Context) -> WKWebView {
        let contentController = WKUserContentController()
        contentController.addScriptMessageHandler(
            context.coordinator,
            contentWorld: .page,
            name: "resObserver"
        )

        let config = WKWebViewConfiguration()
        config.userContentController = contentController
        config.defaultWebpagePreferences.preferredContentMode = .desktop
        config.allowsInlineMediaPlayback = true

        let webView = WKWebView(frame: .zero, configuration: config)
        webView.navigationDelegate = context.coordinator
        webView.customUserAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36"
        webView.scrollView.contentInsetAdjustmentBehavior = .never
        webView.alpha = 0

        setupCookies(webView: webView)

        var finalUrl = urlString.trimmingCharacters(in: .whitespaces)
        if !finalUrl.lowercased().hasPrefix("http") {
            finalUrl = "https://\(finalUrl)"
        }
        if let url = URL(string: finalUrl) {
            webView.load(URLRequest(url: url))
        }

        return webView
    }

    func updateUIView(_ uiView: WKWebView, context: Context) {
        // Vacío intencionalmente: carga y script se gestionan en makeUIView
        // y en los callbacks del WKNavigationDelegate.
    }

    func makeCoordinator() -> Coordinator { Coordinator(self) }

    static func dismantleUIView(_ uiView: WKWebView, coordinator: Coordinator) {
        uiView.configuration.userContentController.removeScriptMessageHandler(
            forName: "resObserver",
            contentWorld: .page
        )
    }

    // MARK: - Coordinator
    class Coordinator: NSObject, WKNavigationDelegate, WKScriptMessageHandlerWithReply {

        var parent: WebViewContainer
        private var scriptInjected = false

        init(_ parent: WebViewContainer) { self.parent = parent }

        // MARK: WKScriptMessageHandlerWithReply
        func userContentController(
            _ userContentController: WKUserContentController,
            didReceive message: WKScriptMessage,
            replyHandler: @escaping (Any?, String?) -> Void
        ) {
            if let dict = message.body as? [String: Any] {
                let w = dict["w"] as? Int ?? 0
                let h = dict["h"] as? Int ?? 0
                DispatchQueue.main.async {
                    self.parent.webWidth = w
                    self.parent.webHeight = h
                }
            }
            replyHandler(nil, nil)
        }

        // MARK: WKNavigationDelegate
        func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
            scriptInjected = false
            applyViewportScript(webView)
            DispatchQueue.main.async { self.parent.errorMessage = nil }
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.5) {
                UIView.animate(withDuration: 0.4) { webView.alpha = 1 }
            }
        }

        func webView(_ webView: WKWebView, didFail navigation: WKNavigation!, withError error: Error) {
            handleNavigationError(error)
        }

        func webView(_ webView: WKWebView, didFailProvisionalNavigation navigation: WKNavigation!, withError error: Error) {
            handleNavigationError(error)
        }

        private func handleNavigationError(_ error: Error) {
            let nsError = error as NSError
            if nsError.code == NSURLErrorCancelled { return }
            DispatchQueue.main.async {
                self.parent.errorMessage = error.localizedDescription
            }
        }

        // MARK: - Viewport Script
        func applyViewportScript(_ webView: WKWebView) {
            guard !scriptInjected else { return }
            scriptInjected = true

            let targetW = parent.targetWidth

            // ─── CÁLCULO CORRECTO DEL SCALE ──────────────────────────────────────────
            //
            // Leemos el ancho de la WKWebView en PUNTOS UIKit desde Swift,
            // ANTES de que JS modifique nada. Esto evita el problema anterior donde
            // window.innerWidth ya estaba contaminado por el viewport modificado.
            //
            // Ejemplo 720p en iPhone 14 Pro (390 pts de ancho):
            //   scale = 390 / 1280 = 0.3047
            //   → El sitio renderiza como si tuviera 1280px de ancho CSS
            //   → Se escala visualmente a 390 puntos de pantalla  ✓
            //
            // La altura visible = puntos de alto / scale
            //   = 844 / 0.3047 = ~2770 px CSS  (razonable, no 11543)
            // ─────────────────────────────────────────────────────────────────────────

            let deviceWidthPts = webView.bounds.width > 0
                ? webView.bounds.width
                : UIScreen.main.bounds.width

            let deviceHeightPts = webView.bounds.height > 0
                ? webView.bounds.height
                : UIScreen.main.bounds.height

            let scale = deviceWidthPts / targetW

            // Altura visible en px CSS (lo que cabe en pantalla sin scroll)
            let visibleHeightCSS = Int((deviceHeightPts / scale).rounded())

            let js = """
            (function() {
                var targetW  = \(Int(targetW));
                var scale    = \(scale);
                var visibleH = \(visibleHeightCSS);

                // Aplicar el viewport con valores calculados desde Swift.
                // NO usamos window.innerWidth aquí porque puede estar ya distorsionado
                // si el viewport fue modificado en una carga anterior.
                var meta = document.querySelector('meta[name="viewport"]');
                if (!meta) {
                    meta = document.createElement('meta');
                    meta.name = 'viewport';
                    document.head.appendChild(meta);
                }
                meta.setAttribute('content',
                    'width='          + targetW  +
                    ',initial-scale=' + scale    +
                    ',minimum-scale=' + scale    +
                    ',maximum-scale=' + scale    +
                    ',user-scalable=no'
                );

                // Reportar ancho configurado + altura visible (sin scroll).
                // Esto es lo que tiene sentido mostrar en el toolbar:
                // "1280 × 2770 px" para 720p, no "1280 × 11543 px" (scroll total).
                window.webkit.messageHandlers.resObserver.postMessage({
                    w: targetW,
                    h: visibleH
                });
            })();
            """

            webView.evaluateJavaScript(js) { _, error in
                if let error = error {
                    print("[WebView] JS error: \(error.localizedDescription)")
                }
            }
        }
    }

    // MARK: - Cookie setup
    private func setupCookies(webView: WKWebView) {
        var finalUrl = urlString.trimmingCharacters(in: .whitespaces)
        if !finalUrl.lowercased().hasPrefix("http") {
            finalUrl = "https://\(finalUrl)"
        }
        guard let parsedURL = URL(string: finalUrl), let host = parsedURL.host else { return }

        let cookieStore = webView.configuration.websiteDataStore.httpCookieStore

        func addCookie(name: String, value: String, domain: String) {
            let props: [HTTPCookiePropertyKey: Any] = [
                .name: name,
                .value: value,
                .domain: domain,
                .path: "/",
                .expires: Date(timeIntervalSinceNow: 31_536_000)
            ]
            if let cookie = HTTPCookie(properties: props) {
                cookieStore.setCookie(cookie)
            }
        }

        if host.contains("youtube.com") {
            addCookie(name: "SOCS",
                      value: "CAISEwgDEgk4OTk4NzM2MzgaAmVzIAEaBgiA2ZXPBg",
                      domain: ".youtube.com")
            let resValue: String
            switch resolution {
            case "4K":   resValue = "2160"
            case "2K":   resValue = "1440"
            case "720p": resValue = "720"
            default:     resValue = "1080"
            }
            addCookie(name: "PREF",
                      value: "f4=4000000&res=\(resValue)",
                      domain: ".youtube.com")
        }

        if host.contains("orbys.eu") {
            addCookie(name: "orbys-consent-cookie", value: "true", domain: ".orbys.eu")
        }
    }
}
