import SwiftUI
import WebKit

// MARK: - Main View
struct ContentView: View {
    @AppStorage("last_url_saved") private var urlText: String = ""
    @State private var selectedResolution = "1080p"
    @State private var showWebView = false

    let resolutions = ["720p", "1080p", "2K", "4K"]

    var body: some View {
        NavigationStack {
            VStack(spacing: 25) {
                Text("WebView Resolution Pro")
                    .font(.system(size: 24, weight: .bold))
                    .padding(.top, 40)

                VStack(alignment: .leading, spacing: 8) {
                    Text("URL de destino")
                        .font(.caption).foregroundColor(.gray)
                    TextField("Introduce la URL", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .autocorrectionDisabled(true)
                        .textInputAutocapitalization(.never)
                }
                .padding(.horizontal)

                VStack(alignment: .leading, spacing: 10) {
                    Text("Resolución Objetivo:")
                        .font(.subheadline).bold()
                    Picker("Resolución", selection: $selectedResolution) {
                        ForEach(resolutions, id: \.self) { res in
                            Text(res).tag(res)
                        }
                    }
                    .pickerStyle(.segmented)
                }
                .padding(.horizontal)

                Spacer()

                Button(action: {
                    if !urlText.isEmpty { showWebView = true }
                }) {
                    Text("LANZAR EN \(selectedResolution)")
                        .font(.headline)
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(urlText.isEmpty ? Color.gray.opacity(0.3) : Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(12)
                }
                .padding(.horizontal).padding(.bottom, 30)
            }
            .navigationDestination(isPresented: $showWebView) {
                WebViewManagerView(urlString: urlText, resolution: selectedResolution)
            }
        }
    }
}

// MARK: - Manager View
struct WebViewManagerView: View {
    let urlString: String
    let resolution: String

    @State private var webWidth: Int = 0
    @State private var webHeight: Int = 0
    @State private var errorMessage: String? = nil
    
    // El secreto: Una ID que cambia con la rotación para forzar el refresco del script
    @State private var rotationTrigger = UUID()

    var body: some View {
        WebViewContainer(
            urlString: urlString,
            resolution: resolution,
            webWidth: $webWidth,
            webHeight: $webHeight,
            errorMessage: $errorMessage,
            rotationTrigger: rotationTrigger // Pasamos el trigger
        )
        .ignoresSafeArea(.container, edges: .bottom)
        .onReceive(NotificationCenter.default.publisher(for: UIDevice.orientationDidChangeNotification)) { _ in
            // Cuando el iPhone gira, esperamos un momento y disparamos la actualización
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.4) {
                self.rotationTrigger = UUID()
            }
        }
        .toolbar {
            ToolbarItem(placement: .principal) {
                Text("\(webWidth) × \(webHeight) px").font(.caption.monospaced()).bold().foregroundColor(.blue)
            }
        }
    }
}

// MARK: - WebView Container
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    let resolution: String
    @Binding var webWidth: Int
    @Binding var webHeight: Int
    @Binding var errorMessage: String?
    let rotationTrigger: UUID // Detecta cambios desde fuera

    var baseLong: CGFloat {
        switch resolution {
        case "720p": return 1280
        case "1080p": return 1920
        case "2K": return 2560
        case "4K": return 3840
        default: return 1920
        }
    }
    
    var baseShort: CGFloat {
        switch resolution {
        case "720p": return 720
        case "1080p": return 1080
        case "2K": return 1440
        case "4K": return 2160
        default: return 1080
        }
    }

    func makeUIView(context: Context) -> WKWebView {
        let config = WKWebViewConfiguration()
        config.userContentController.add(context.coordinator, name: "resObserver")
        config.defaultWebpagePreferences.preferredContentMode = .desktop
        config.allowsInlineMediaPlayback = true

        let webView = WKWebView(frame: .zero, configuration: config)
        webView.navigationDelegate = context.coordinator
        webView.customUserAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36"
        webView.scrollView.contentInsetAdjustmentBehavior = .never
        
        setupCookies(webView: webView)
        
        if let url = URL(string: urlString.contains("http") ? urlString : "https://\(urlString)") {
            webView.load(URLRequest(url: url))
        }
        return webView
    }

    func updateUIView(_ uiView: WKWebView, context: Context) {
        // Cada vez que rotationTrigger cambia (al rotar), se ejecuta esto
        context.coordinator.applyViewport(uiView)
    }

    func makeCoordinator() -> Coordinator { Coordinator(self) }

    class Coordinator: NSObject, WKNavigationDelegate, WKScriptMessageHandler {
        var parent: WebViewContainer
        init(_ parent: WebViewContainer) { self.parent = parent }

        func userContentController(_ userContentController: WKUserContentController, didReceive message: WKScriptMessage) {
            if let dict = message.body as? [String: Any] {
                DispatchQueue.main.async {
                    self.parent.webWidth = dict["w"] as? Int ?? 0
                    self.parent.webHeight = dict["h"] as? Int ?? 0
                }
            }
        }

        func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
            applyViewport(webView)
        }

        func applyViewport(_ webView: WKWebView) {
            let width = webView.bounds.width
            let height = webView.bounds.height
            guard width > 0 else { return }

            let isLandscape = width > height
            let targetW = isLandscape ? parent.baseLong : parent.baseShort
            let targetH = isLandscape ? parent.baseShort : parent.baseLong
            
            // Calculamos la escala exacta según el ancho actual del iPhone
            let scale = width / targetW

            let js = """
            var meta = document.querySelector('meta[name="viewport"]');
            if (!meta) {
                meta = document.createElement('meta');
                meta.name = 'viewport';
                document.head.appendChild(meta);
            }
            meta.setAttribute('content', 'width=\(Int(targetW)), initial-scale=\(scale), minimum-scale=\(scale), maximum-scale=\(scale), user-scalable=no');
            window.webkit.messageHandlers.resObserver.postMessage({w: \(Int(targetW)), h: \(Int(targetH))});
            """
            webView.evaluateJavaScript(js)
        }
    }

    private func setupCookies(webView: WKWebView) {
        guard let host = URL(string: urlString.contains("http") ? urlString : "https://\(urlString)")?.host else { return }
        let store = webView.configuration.websiteDataStore.httpCookieStore
        
        if host.contains("youtube.com") {
            let resValue = resolution == "4K" ? "2160" : (resolution == "2K" ? "1440" : (resolution == "720p" ? "720" : "1080"))
            let cookie = HTTPCookie(properties: [.name: "PREF", .value: "f4=4000000&res=\(resValue)", .domain: ".youtube.com", .path: "/", .expires: Date(timeIntervalSinceNow: 31536000)])!
            store.setCookie(cookie)
        }
    }
}
