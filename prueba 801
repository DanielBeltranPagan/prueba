import SwiftUI
import WebKit

// MARK: - Main View
struct ContentView: View {
    @AppStorage("last_url_saved") private var urlText: String = ""
    @State private var selectedResolution = "1080p"
    @State private var showWebView = false

    let resolutions = ["720p", "1080p", "2K", "4K"]

    var body: some View {
        NavigationStack {
            VStack(spacing: 25) {
                Text("WebView Resolution Pro")
                    .font(.system(size: 24, weight: .bold))
                    .padding(.top, 40)

                VStack(alignment: .leading, spacing: 8) {
                    Text("URL de destino").font(.caption).foregroundColor(.gray)
                    TextField("Introduce la URL (ej: youtube.com)", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .textContentType(.URL)
                        .keyboardType(.URL)
                        .autocorrectionDisabled(true)
                        .textInputAutocapitalization(.never)
                }
                .padding(.horizontal)

                VStack(alignment: .leading, spacing: 10) {
                    Text("Resolución Objetivo (Ancho):").font(.subheadline).bold()
                    Picker("Resolución", selection: $selectedResolution) {
                        ForEach(resolutions, id: \.self) { Text($0).tag($0) }
                    }
                    .pickerStyle(.segmented)
                }
                .padding(.horizontal)

                Spacer()

                Button(action: { showWebView = true }) {
                    Text("LANZAR EN \(selectedResolution)")
                        .font(.headline)
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(urlText.isEmpty ? Color.gray.opacity(0.3) : Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(12)
                }
                .disabled(urlText.isEmpty)
                .padding(.horizontal).padding(.bottom, 30)
            }
            .navigationDestination(isPresented: $showWebView) {
                WebViewManagerView(urlString: urlText, resolution: selectedResolution)
            }
        }
    }
}

// MARK: - Manager View
struct WebViewManagerView: View {
    let urlString: String
    let resolution: String
    @State private var webSize: (w: Int, h: Int) = (0, 0)
    @State private var errorMessage: String? = nil
    @State private var isReady: Bool = false // Pantalla de carga

    var body: some View {
        ZStack {
            if let error = errorMessage {
                VStack(spacing: 16) {
                    Image(systemName: "wifi.slash").font(.system(size: 48)).foregroundColor(.gray)
                    Text("Error de navegación").font(.headline)
                    Text(error).font(.caption).foregroundColor(.secondary).multilineTextAlignment(.center)
                }.padding()
            } else {
                // El WebView se oculta hasta que esté listo
                WebViewContainer(urlString: urlString, resolution: resolution, webSize: $webSize, errorMessage: $errorMessage, isReady: $isReady)
                    .ignoresSafeArea(.container, edges: .bottom)
                    .opacity(isReady ? 1 : 0)
            }

            if !isReady && errorMessage == nil {
                Color(UIColor.systemBackground).ignoresSafeArea()
                VStack(spacing: 20) {
                    ProgressView()
                    Text("Ajustando resolución...").font(.footnote).foregroundColor(.gray)
                }
            }
        }
        .toolbar {
            ToolbarItem(placement: .principal) {
                HStack(spacing: 6) {
                    Image(systemName: errorMessage != nil ? "exclamationmark.triangle" : "viewfinder")
                    Text(errorMessage != nil ? "Error" : (webSize.w > 0 ? "\(webSize.w) × \(webSize.h) px" : "Cargando…"))
                        .font(.system(size: 14, weight: .bold, design: .monospaced))
                }
                .foregroundColor(errorMessage != nil ? .orange : .blue)
            }
        }
        .navigationBarTitleDisplayMode(.inline)
    }
}

// MARK: - WebView Container
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    let resolution: String
    @Binding var webSize: (w: Int, h: Int)
    @Binding var errorMessage: String?
    @Binding var isReady: Bool

    func makeUIView(context: Context) -> WKWebView {
        let config = WKWebViewConfiguration()
        config.userContentController.add(context.coordinator, name: "resObserver")
        config.defaultWebpagePreferences.preferredContentMode = .desktop
        
        let webView = WKWebView(frame: .zero, configuration: config)
        webView.navigationDelegate = context.coordinator
        webView.scrollView.contentInsetAdjustmentBehavior = .never
        webView.customUserAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36"
        
        let formatted = urlString.lowercased().hasPrefix("http") ? urlString : "https://\(urlString)"
        if let url = URL(string: formatted.trimmingCharacters(in: .whitespaces)) {
            setupCookies(webView: webView, url: url)
            webView.load(URLRequest(url: url))
        }
        return webView
    }

    func updateUIView(_ uiView: WKWebView, context: Context) {}
    func makeCoordinator() -> Coordinator { Coordinator(self) }

    class Coordinator: NSObject, WKNavigationDelegate, WKScriptMessageHandler {
        var parent: WebViewContainer
        init(_ parent: WebViewContainer) { self.parent = parent }

        func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
            applyResolution(webView)
        }

        func webView(_ webView: WKWebView, didFail navigation: WKNavigation!, withError error: Error) {
            parent.errorMessage = error.localizedDescription
        }

        func userContentController(_ userContentController: WKUserContentController, didReceive message: WKScriptMessage) {
            if let dict = message.body as? [String: Int] {
                parent.webSize = (dict["w"] ?? 0, dict["h"] ?? 0)
                withAnimation { parent.isReady = true }
            }
        }

        private func applyResolution(_ webView: WKWebView) {
            let resMap: [String: (CGFloat, CGFloat)] = ["720p":(1280,720), "1080p":(1920,1080), "2K":(2560,1440), "4K":(3840,2160)]
            let spec = resMap[parent.resolution] ?? (1920, 1080)
            let isLandscape = webView.bounds.width > webView.bounds.height
            let targetW = isLandscape ? spec.0 : spec.1
            let scale = webView.bounds.width / targetW

            let js = """
                var meta = document.querySelector('meta[name="viewport"]') || document.createElement('meta');
                meta.name = 'viewport';
                meta.content = 'width=\(targetW), initial-scale=\(scale), minimum-scale=\(scale), user-scalable=no';
                document.head.appendChild(meta);
                window.webkit.messageHandlers.resObserver.postMessage({w: \(Int(targetW)), h: \(Int(spec.1))});
            """
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.5) {
                webView.evaluateJavaScript(js)
            }
        }
    }

    private func setupCookies(webView: WKWebView, url: URL) {
        let store = webView.configuration.websiteDataStore.httpCookieStore
        if url.host?.contains("youtube.com") == true {
            let res = resolution.replacingOccurrences(of: "p", with: "")
            let cookies = ["SOCS": "CAISEwgDEgk4OTk4NzM2MzgaAmVzIAEaBgiA2ZXPBg", "PREF": "f4=4000000&res=\(res)"]
            cookies.forEach { name, value in
                let p: [HTTPCookiePropertyKey: Any] = [.name: name, .value: value, .domain: ".youtube.com", .path: "/", .expires: Date(timeIntervalSinceNow: 31536000)]
                if let c = HTTPCookie(properties: p) { store.setCookie(c) }
            }
        }
    }
}
