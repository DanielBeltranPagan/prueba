import SwiftUI
import WebKit

struct ContentView: View {
    @AppStorage("last_url_saved") private var urlText: String = ""
    @State private var selectedResolution = "720p"
    @State private var showWebView = false
    
    let resolutions = ["720p", "1080p", "2K", "4K"]
    
    var body: some View {
        NavigationStack {
            VStack(spacing: 25) {
                Text("WebView Resolution Pro")
                    .font(.system(size: 24, weight: .bold))
                    .padding(.top, 40)
                
                VStack(alignment: .leading, spacing: 8) {
                    Text("URL de destino")
                        .font(.caption)
                        .foregroundColor(.gray)
                    
                    TextField("Introduce la URL (ej: youtube.com)", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .textContentType(.URL)
                        .keyboardType(.URL)
                        .autocorrectionDisabled(true)
                        .textInputAutocapitalization(.never)
                }
                .padding(.horizontal)
                
                VStack(alignment: .leading, spacing: 10) {
                    Text("Selección de Resolución:")
                        .font(.subheadline).bold()
                    
                    Picker("Resolución", selection: $selectedResolution) {
                        ForEach(resolutions, id: \.self) { res in
                            Text(res).tag(res)
                        }
                    }
                    .pickerStyle(.segmented)
                }
                .padding(.horizontal)
                
                Spacer()
                
                Button(action: {
                    if !urlText.trimmingCharacters(in: .whitespaces).isEmpty {
                        showWebView = true
                    }
                }) {
                    Text("LANZAR EN \(selectedResolution)")
                        .font(.headline)
                        .frame(maxWidth: .infinity)
                        .padding()
                        .background(urlText.isEmpty ? Color.gray.opacity(0.3) : Color.blue)
                        .foregroundColor(.white)
                        .cornerRadius(12)
                }
                .disabled(urlText.isEmpty)
                .padding(.horizontal)
                .padding(.bottom, 30)
            }
            .navigationDestination(isPresented: $showWebView) {
                GeometryReader { geo in
                    let screenScale = UIScreen.main.scale
                    // Estos son los píxeles reales que el dispositivo está usando para dibujar
                    let pixelWidth = Int(geo.size.width * screenScale)
                    let pixelHeight = Int(geo.size.height * screenScale)
                    
                    WebViewContainer(urlString: urlText, resolution: selectedResolution)
                        .ignoresSafeArea(.container, edges: .bottom)
                        .toolbar {
                            ToolbarItem(placement: .principal) {
                                Text("\(pixelWidth) x \(pixelHeight) PX")
                                    .font(.system(size: 18, weight: .bold, design: .monospaced))
                            }
                        }
                }
                .navigationBarTitleDisplayMode(.inline)
            }
        }
    }
}

// MARK: - WebView Container
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    let resolution: String
    
    private var targetWidth: CGFloat {
        switch resolution {
        case "720p": return 1280  // Ancho estándar HD
        case "1080p": return 1920 // Full HD
        case "2K": return 2560
        case "4K": return 3840
        default: return 1920
        }
    }

    func makeUIView(context: Context) -> WKWebView {
        let config = WKWebViewConfiguration()
        // Forzamos modo escritorio a nivel de configuración
        config.defaultWebpagePreferences.preferredContentMode = .desktop
        
        let webView = WKWebView(frame: .zero, configuration: config)
        webView.navigationDelegate = context.coordinator
        
        // User Agent de Chrome Desktop para que la web no intente enviar la versión móvil
        webView.customUserAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
        
        webView.alpha = 0 
        webView.scrollView.contentInsetAdjustmentBehavior = .never // Evita saltos de la barra de estado
        
        return webView
    }

    func updateUIView(_ uiView: WKWebView, context: Context) {
        var finalUrl = urlString.trimmingCharacters(in: .whitespaces)
        if !finalUrl.lowercased().hasPrefix("http") { finalUrl = "https://\(finalUrl)" }
        guard let url = URL(string: finalUrl) else { return }
        
        if uiView.url == nil { uiView.load(URLRequest(url: url)) }
        
        // Re-ajuste en cada actualización (rotación)
        DispatchQueue.main.async {
            context.coordinator.applyRobustScale(to: uiView)
        }
    }

    func makeCoordinator() -> Coordinator { Coordinator(self) }

    class Coordinator: NSObject, WKNavigationDelegate {
        var parent: WebViewContainer
        init(_ parent: WebViewContainer) { self.parent = parent }

        func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
            applyRobustScale(to: webView)
            
            // Retraso para que el motor de renderizado procese el JS de escalado
            DispatchQueue.main.asyncAfter(deadline: .now() + 0.8) {
                UIView.animate(withDuration: 0.4) { webView.alpha = 1 }
            }
        }
        
        func applyRobustScale(to webView: WKWebView) {
            let screenWidth = webView.frame.width > 0 ? webView.frame.width : UIScreen.main.bounds.width
            let scale = screenWidth / parent.targetWidth
            
            // Este script hace tres cosas:
            // 1. Fuerza el viewport al ancho objetivo (ej: 1920)
            // 2. Escala el documento entero para que quepa en la pantalla del iPhone
            // 3. Desactiva el ajuste automático de texto de iOS
            let js = """
            (function() {
                var meta = document.querySelector('meta[name="viewport"]');
                if(!meta) { 
                    meta = document.createElement('meta'); 
                    meta.name = "viewport"; 
                    document.head.appendChild(meta); 
                }
                meta.setAttribute('content', 'width=\(Int(parent.targetWidth)), initial-scale=\(scale), minimum-scale=\(scale), maximum-scale=5.0');
                
                document.documentElement.style.width = '\(Int(parent.targetWidth))px';
                document.body.style.width = '\(Int(parent.targetWidth))px';
                document.documentElement.style.zoom = "\(scale)";
                document.body.style.webkitTextSizeAdjust = 'none';
            })();
            """
            
            webView.evaluateJavaScript(js)
        }
    }
}

