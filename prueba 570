import SwiftUI
import WebKit

// MARK: - Resolution Spec

struct ResolutionSpec {
    let longSide: CGFloat   // siempre el lado mayor (landscape width)
    let shortSide: CGFloat  // siempre el lado menor (landscape height)

    static func from(_ resolution: String) -> ResolutionSpec {
        switch resolution {
        case "720p":  return .init(longSide: 1280, shortSide: 720)
        case "1080p": return .init(longSide: 1920, shortSide: 1080)
        case "2K":    return .init(longSide: 2560, shortSide: 1440)
        case "4K":    return .init(longSide: 3840, shortSide: 2160)
        default:      return .init(longSide: 1920, shortSide: 1080)
        }
    }

    func adapted(isLandscape: Bool) -> (w: Int, h: Int) {
        isLandscape
            ? (w: Int(longSide),  h: Int(shortSide))
            : (w: Int(shortSide), h: Int(longSide))
    }
}

