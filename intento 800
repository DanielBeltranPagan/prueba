import SwiftUI
import WebKit

// MARK: - Main View
struct ContentView: View {
    @AppStorage("last_url_saved") private var urlText = ""
    @State private var selectedRes = "1080p"
    @State private var showWebView = false
    let resolutions = ["720p", "1080p", "2K", "4K"]

    var body: some View {
        NavigationStack {
            VStack(spacing: 20) {
                Text("WebView Resolution Pro").font(.title.bold()).padding(.top)
                
                VStack(alignment: .leading) {
                    Text("URL de destino").font(.caption).foregroundColor(.gray)
                    TextField("ej: youtube.com", text: $urlText)
                        .textFieldStyle(.roundedBorder)
                        .textInputAutocapitalization(.never)
                        .keyboardType(.URL)
                }.padding(.horizontal)

                Picker("Resolución", selection: $selectedRes) {
                    ForEach(resolutions, id: \.self) { Text($0) }
                }.pickerStyle(.segmented).padding(.horizontal)

                Spacer()

                Button(action: { showWebView = true }) {
                    Text("LANZAR EN \(selectedRes)")
                        .bold().frame(maxWidth: .infinity).padding()
                        .background(urlText.isEmpty ? Color.gray : Color.blue)
                        .foregroundColor(.white).cornerRadius(12)
                }.disabled(urlText.isEmpty).padding()
            }
            .navigationDestination(isPresented: $showWebView) {
                WebViewManagerView(urlString: urlText, resolution: selectedRes)
            }
        }
    }
}

// MARK: - Manager View
struct WebViewManagerView: View {
    let urlString: String
    let resolution: String
    @State private var size: (w: Int, h: Int) = (0, 0)
    @State private var error: String?

    var body: some View {
        ZStack {
            if let error = error {
                VStack {
                    Image(systemName: "wifi.slash").font(.largeTitle)
                    Text(error).font(.caption).multilineTextAlignment(.center)
                }.padding()
            } else {
                WebViewContainer(urlString: urlString, resolution: resolution, size: $size, error: $error)
                    .ignoresSafeArea(.container, edges: .bottom)
            }
        }
        .toolbar {
            ToolbarItem(placement: .principal) {
                Text(size.w > 0 ? "\(size.w) × \(size.h) px" : "Cargando...")
                    .font(.caption.monospaced().bold()).foregroundColor(.blue)
            }
        }
    }
}

// MARK: - WebView Container
struct WebViewContainer: UIViewRepresentable {
    let urlString: String
    let resolution: String
    @Binding var size: (w: Int, h: Int)
    @Binding var error: String?

    func makeUIView(context: Context) -> WKWebView {
        let config = WKWebViewConfiguration()
        let controller = WKUserContentController()
        
        // Listener de resolución
        controller.add(context.coordinator, name: "resObserver")
        config.userContentController = controller
        config.defaultWebpagePreferences.preferredContentMode = .desktop
        
        let webView = WKWebView(frame: .zero, configuration: config)
        webView.navigationDelegate = context.coordinator
        webView.scrollView.contentInsetAdjustmentBehavior = .never
        webView.customUserAgent = "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/115.0.0.0 Safari/537.36"
        
        loadRequest(in: webView)
        return webView
    }

    func updateUIView(_ uiView: WKWebView, context: Context) {}

    private func loadRequest(in webView: WKWebView) {
        let formatted = urlString.lowercased().hasPrefix("http") ? urlString : "https://\(urlString)"
        if let url = URL(string: formatted.trimmingCharacters(in: .whitespaces)) {
            setupCookies(for: url, in: webView)
            webView.load(URLRequest(url: url))
        }
    }

    func makeCoordinator() -> Coordinator { Coordinator(self) }

    class Coordinator: NSObject, WKNavigationDelegate, WKScriptMessageHandler {
        var parent: WebViewContainer
        init(_ parent: WebViewContainer) { self.parent = parent }

        func webView(_ webView: WKWebView, didFinish navigation: WKNavigation!) {
            applyViewport(webView)
        }

        func webView(_ webView: WKWebView, didFail navigation: WKNavigation!, withError error: Error) {
            parent.error = error.localizedDescription
        }

        func userContentController(_ userContentController: WKUserContentController, didReceive message: WKScriptMessage) {
            if let dict = message.body as? [String: Int] {
                parent.size = (dict["w"] ?? 0, dict["h"] ?? 0)
            }
        }

        func applyViewport(_ webView: WKWebView) {
            let resMap: [String: (CGFloat, CGFloat)] = [
                "720p": (1280, 720), "1080p": (1920, 1080), "2K": (2560, 1440), "4K": (3840, 2160)
            ]
            let spec = resMap[parent.resolution] ?? (1920, 1080)
            let isLandscape = webView.bounds.width > webView.bounds.height
            let targetW = isLandscape ? spec.0 : spec.1
            let targetH = isLandscape ? spec.1 : spec.0
            let scale = webView.bounds.width / targetW

            let js = """
                var meta = document.querySelector('meta[name="viewport"]') || document.createElement('meta');
                meta.name = 'viewport';
                meta.content = 'width=\(targetW), initial-scale=\(scale), minimum-scale=\(scale), user-scalable=no';
                document.head.appendChild(meta);
                window.webkit.messageHandlers.resObserver.postMessage({w: \(Int(targetW)), h: \(Int(targetH))});
            """
            webView.evaluateJavaScript(js)
        }
    }
    
    private func setupCookies(for url: URL, in webView: WKWebView) {
        let store = webView.configuration.websiteDataStore.httpCookieStore
        let domain = url.host ?? ""
        
        if domain.contains("youtube.com") {
            let res = resolution.replacingOccurrences(of: "p", with: "")
            let cookies = [
                "SOCS": "CAISEwgDEgk4OTk4NzM2MzgaAmVzIAEaBgiA2ZXPBg",
                "PREF": "f4=4000000&res=\(res)"
            ]
            cookies.forEach { name, value in
                if let cookie = HTTPCookie(properties: [.name: name, .value: value, .domain: ".youtube.com", .path: "/", .expires: Date(timeIntervalSinceNow: 31536000)]) {
                    store.setCookie(cookie)
                }
            }
        }
    }
}
